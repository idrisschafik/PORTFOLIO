---
/**
 * Skills.astro
 * ============
 * Technical skills in a card grid with icons, category titles, and chip pills.
 * Optional soft skills sub-section with icon + description layout.
 */
import { technicalSkills, softSkills } from '../data/portfolio';

const iconPaths: Record<string, string> = {
  'code': '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  'server': '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  'database': '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  'tool': '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  'users': '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'lightbulb': '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  'clock': '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'trending-up': '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  'cpu': '<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>',
};

const hasSoftSkills = softSkills.length > 0;
---

{technicalSkills.length > 0 && (
  <section class="skills section" id="skills">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths['cpu']} /></svg>
          Skills
        </span>
        <h2 class="section__title">My Tech Stack</h2>
      </div>

      <!-- Technical Skills -->
      <div class="divider reveal">
        <div class="divider__line"></div>
        <span class="divider__text">Technical Skills</span>
        <div class="divider__line"></div>
      </div>

      <div class="skills__grid reveal-stagger">
        {technicalSkills.map((cat) => (
          <div class="skills__card card reveal">
            <div class="skills__icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths[cat.icon] || ''} /></svg>
            </div>
            <h3 class="skills__card-title">{cat.title}</h3>
            <div class="skills__chips">
              {cat.skills.map((skill) => (
                <span class="skills__chip">{skill}</span>
              ))}
            </div>
            <span class="skills__count">{cat.skills.length} skills</span>
          </div>
        ))}
      </div>

      <!-- Soft Skills (optional) -->
      {hasSoftSkills && (
        <>
          <div class="divider reveal">
            <div class="divider__line"></div>
            <span class="divider__text">Soft Skills</span>
            <div class="divider__line"></div>
          </div>

          <div class="skills__soft-grid reveal-stagger">
            {softSkills.map((skill) => (
              <div class="skills__soft-item card reveal">
                <div class="skills__soft-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths[skill.icon] || ''} /></svg>
                </div>
                <div>
                  <h4 class="skills__soft-name">{skill.name}</h4>
                  <p class="skills__soft-desc">{skill.description}</p>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
)}

<style>
  /* ── Technical Skills Grid ── */
  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .skills__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skills__icon-box {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .skills__icon-box svg {
    width: 22px;
    height: 22px;
    color: var(--color-primary-light);
    transition: transform var(--transition-base);
  }

  .skills__card:hover .skills__icon-box {
    background: rgba(99, 102, 241, 0.15);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
  }

  .skills__card:hover .skills__icon-box svg {
    transform: scale(1.15);
  }

  .skills__card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skills__chip {
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 9999px;
    color: var(--color-primary-light);
    transition: all var(--transition-fast);
  }

  .skills__chip:hover {
    background: rgba(99, 102, 241, 0.15);
    border-color: rgba(99, 102, 241, 0.3);
  }

  .skills__count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.6;
    margin-top: auto;
  }

  /* ── Soft Skills Grid ── */
  .skills__soft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .skills__soft-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
  }

  .skills__soft-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(167, 139, 250, 0.1);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .skills__soft-icon svg {
    width: 18px;
    height: 18px;
    color: var(--color-accent);
    transition: transform var(--transition-base);
  }

  .skills__soft-item:hover .skills__soft-icon {
    background: rgba(167, 139, 250, 0.15);
    box-shadow: 0 0 15px rgba(167, 139, 250, 0.15);
  }

  .skills__soft-item:hover .skills__soft-icon svg {
    transform: scale(1.15);
  }

  .skills__soft-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .skills__soft-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
