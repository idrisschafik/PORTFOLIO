---
/**
 * About.astro
 * ===========
 * Two-column grid of numbered cards with accent bars and stagger animations.
 */
import { aboutCards } from '../data/portfolio';

const iconPath = '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>';
---

{aboutCards.length > 0 && (
  <section class="about section" id="about">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPath} /></svg>
          About Me
        </span>
        <h2 class="section__title">Get to Know Me</h2>
      </div>

      <div class="about__grid reveal-stagger">
        {aboutCards.map((card) => (
          <div class="about__card card reveal">
            <div class="about__card-accent"></div>
            <span class="about__card-number">{card.number}</span>
            <p class="about__card-text">{card.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .about__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .about__card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-left: 2rem;
  }

  .about__card-accent {
    position: absolute;
    left: 0;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 3px;
    background: var(--gradient-primary);
    border-radius: 2px;
  }

  .about__card-number {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary-light);
    opacity: 0.7;
  }

  .about__card-text {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
