---
/**
 * Contact.astro
 * =============
 * Two-column contact section: info cards + social links on left, functional
 * form on right. Uses formsubmit.co for form handling.
 */
import { personalInfo, socialLinks } from '../data/portfolio';

const iconPaths: Record<string, string> = {
  'mail': '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  'phone': '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  'map-pin': '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  'send': '<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>',
  'github': '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  'linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
};

const contactItems = [
  { icon: 'mail', label: 'Email', value: personalInfo.emails[0], href: `mailto:${personalInfo.emails[0]}` },
  ...(personalInfo.phone ? [{ icon: 'phone', label: 'Phone', value: personalInfo.phone, href: `tel:${personalInfo.phone}` }] : []),
  { icon: 'map-pin', label: 'Location', value: personalInfo.location },
];

const formAction = `https://formsubmit.co/${personalInfo.emails[0]}`;
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths['send']} /></svg>
        Contact
      </span>
      <h2 class="section__title">Get in Touch</h2>
    </div>

    <div class="contact__grid">
      <!-- Info Column -->
      <div class="contact__info reveal">
        <div class="contact__cards">
          {contactItems.map((item) => (
            <div class="contact__card card">
              <div class="contact__icon-box">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths[item.icon] || ''} /></svg>
              </div>
              <div>
                <span class="contact__card-label">{item.label}</span>
                {item.href ? (
                  <a href={item.href} class="contact__card-value">{item.value}</a>
                ) : (
                  <span class="contact__card-value contact__card-value--plain">{item.value}</span>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Social Links -->
        <div class="contact__socials">
          {socialLinks.map((link) => (
            <a href={link.url} class="contact__social" target="_blank" rel="noopener noreferrer" aria-label={link.label}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths[link.icon] || ''} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Form Column -->
      <form class="contact__form card reveal" action={formAction} method="POST">
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value={`${Astro.site || ''}#contact`} />

        <div class="contact__field">
          <label for="name" class="contact__label">Your Name</label>
          <input type="text" id="name" name="name" class="contact__input" required placeholder="John Doe" />
        </div>

        <div class="contact__field">
          <label for="email" class="contact__label">Your Email</label>
          <input type="email" id="email" name="email" class="contact__input" required placeholder="john@example.com" />
        </div>

        <div class="contact__field">
          <label for="subject" class="contact__label">Subject</label>
          <input type="text" id="subject" name="_subject" class="contact__input" required placeholder="Project Collaboration" />
        </div>

        <div class="contact__field">
          <label for="message" class="contact__label">Message</label>
          <textarea id="message" name="message" class="contact__input contact__textarea" required placeholder="Hello, I'd like to discuss..." rows="5"></textarea>
        </div>

        <button type="submit" class="contact__submit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={iconPaths['send']} /></svg>
          Send Message
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Info Column ── */
  .contact__cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
  }

  .contact__icon-box {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-md);
    flex-shrink: 0;
    transition: all var(--transition-base);
  }

  .contact__icon-box svg {
    width: 20px;
    height: 20px;
    color: var(--color-primary-light);
    transition: transform var(--transition-base);
  }

  .contact__card:hover .contact__icon-box {
    background: rgba(99, 102, 241, 0.15);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.15);
  }

  .contact__card:hover .contact__icon-box svg {
    transform: scale(1.1);
  }

  .contact__card-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
  }

  .contact__card-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
  }

  .contact__card-value:hover {
    color: var(--color-primary-light);
  }

  .contact__card-value--plain {
    color: var(--color-text);
  }

  .contact__socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .contact__social {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    transition: all var(--transition-base);
  }

  .contact__social svg {
    width: 20px;
    height: 20px;
  }

  .contact__social:hover {
    color: var(--color-primary-light);
    border-color: var(--color-border-hover);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  /* ── Form ── */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact__label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .contact__input {
    padding: 0.75rem 1rem;
    background: rgba(10, 15, 30, 0.8);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
  }

  .contact__input::placeholder {
    color: rgba(148, 163, 184, 0.4);
  }

  .contact__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--gradient-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-base);
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.3);
  }

  .contact__submit svg {
    width: 18px;
    height: 18px;
  }

  .contact__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(99, 102, 241, 0.5);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
