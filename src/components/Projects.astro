---
/**
 * Projects.astro
 * ==============
 * Grid of project cards with watermark numbers, tags, links, and hover effects.
 */
import { projects } from '../data/portfolio';

const folderIcon = '<path d="M9 20H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v5"/><circle cx="13" cy="12" r="2"/><path d="M18 19c-2.8 0-5 2.2-5 5"/><circle cx="20" cy="19" r="2"/>';
const externalLinkIcon = '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>';
const githubIcon = '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>';
const arrowIcon = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
---

{projects.length > 0 && (
  <section class="projects section" id="projects">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={folderIcon} /></svg>
          Projects
        </span>
        <h2 class="section__title">What I've Built</h2>
      </div>

      <div class="projects__grid reveal-stagger">
        {projects.map((project, i) => (
          <div class="projects__card card reveal">
            <span class="projects__number gradient-text">{String(i + 1).padStart(2, '0')}</span>

            <h3 class="projects__title">
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="projects__title-link">
                  {project.title}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={externalLinkIcon} /></svg>
                </a>
              ) : (
                project.title
              )}
            </h3>

            <p class="projects__desc">{project.description}</p>

            <div class="projects__tags">
              {project.tags.map((tag) => (
                <span class="projects__tag">{tag}</span>
              ))}
            </div>

            <div class="projects__links">
              {project.url && (
                <a href={project.url} class="projects__link" target="_blank" rel="noopener noreferrer">
                  View Project
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={arrowIcon} /></svg>
                </a>
              )}
              {project.github && (
                <a href={project.github} class="projects__link projects__link--github" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={githubIcon} /></svg>
                  Source
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .projects__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 280px;
  }

  .projects__number {
    font-family: var(--font-mono);
    font-size: 3.5rem;
    font-weight: 900;
    opacity: 0.12;
    line-height: 1;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    pointer-events: none;
  }

  .projects__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .projects__title-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .projects__title-link svg {
    width: 16px;
    height: 16px;
    color: var(--color-primary-light);
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .projects__title-link:hover {
    color: var(--color-primary-light);
  }

  .projects__title-link:hover svg {
    opacity: 1;
  }

  .projects__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .projects__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .projects__tag {
    padding: 0.25rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 500;
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.15);
    border-radius: 9999px;
    color: var(--color-accent);
  }

  .projects__links {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .projects__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary-light);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .projects__link svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .projects__link:hover {
    color: var(--color-accent);
  }

  .projects__link:hover svg {
    transform: translateX(4px);
  }

  .projects__link--github svg {
    transition: none;
  }

  .projects__link--github:hover svg {
    transform: none;
  }

  @media (max-width: 768px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
